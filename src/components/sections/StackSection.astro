---
import SectionTitle from '../ui/SectionTitle.astro';
import TechCategoryCard from '../ui/TechCategoryCard.astro';
import { techStack } from '../../data/stack';
---

<section id="stack" class="relative w-full min-h-screen bg-[#0a0a0a] flex flex-col items-center justify-center py-24 px-4 md:px-8 overflow-hidden snap-start">
  <div class="absolute inset-0 bg-[linear-gradient(90deg,#e6394608_1px,transparent_1px),linear-gradient(180deg,#e6394608_1px,transparent_1px)] bg-[size:50px_50px] pointer-events-none z-0"></div>

  <div class="absolute inset-0 pointer-events-none hidden sm:block">
    <div class="absolute w-[40px] h-[40px] md:w-[60px] md:h-[60px] border-2 border-[#e6394630] top-8 left-8 border-r-0 border-b-0"></div>
    <div class="absolute w-[40px] h-[40px] md:w-[60px] md:h-[60px] border-2 border-[#e6394630] top-8 right-8 border-l-0 border-b-0"></div>
    <div class="absolute w-[40px] h-[40px] md:w-[60px] md:h-[60px] border-2 border-[#e6394630] bottom-8 left-8 border-r-0 border-t-0"></div>
    <div class="absolute w-[40px] h-[40px] md:w-[60px] md:h-[60px] border-2 border-[#e6394630] bottom-8 right-8 border-l-0 border-t-0"></div>
  </div>

  <div class="absolute w-[300px] h-[300px] md:w-[400px] md:h-[400px] rounded-full blur-[100px] pointer-events-none -top-[100px] -right-[100px] bg-[radial-gradient(circle,rgba(230,57,70,0.12)_0%,transparent_70%)]"></div>
  <div class="absolute w-[200px] h-[200px] md:w-[300px] md:h-[300px] rounded-full blur-[100px] pointer-events-none -bottom-[50px] -left-[50px] bg-[radial-gradient(circle,rgba(230,57,70,0.09)_0%,transparent_70%)]"></div>

  <SectionTitle 
    label="SKILLS & EXPERTISE"
    title="TECH"
    highlight="STACK"
    variant="dark"
    centered={true}
  />

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 w-full max-w-[1200px] relative z-10">
    {techStack.map((category) => (
      <TechCategoryCard category={category} />
    ))}
  </div>
</section>
