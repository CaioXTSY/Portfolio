---
import { experiences } from '../../data/experiences';
import CornerDecorations from '../ui/CornerDecorations.astro';
---

<section id="experience" id="experience" class="w-full min-h-screen relative bg-[#fafafa] snap-start overflow-hidden flex items-center justify-center py-24 px-4 md:px-8">
  <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(0,0,0,0.03)_1px,transparent_1px),linear-gradient(0deg,rgba(0,0,0,0.03)_1px,transparent_1px)] bg-[size:60px_60px] pointer-events-none z-0"></div>

  <div class="absolute inset-0 flex justify-between px-[10%] pointer-events-none z-0">
    <div class="w-[1px] h-full bg-gradient-to-b from-transparent via-[#e6394612] to-transparent opacity-50"></div>
    <div class="w-[1px] h-full bg-gradient-to-b from-transparent via-[#e6394612] to-transparent opacity-80"></div>
    <div class="w-[1px] h-full bg-gradient-to-b from-transparent via-[#e6394612] to-transparent opacity-100"></div>
    <div class="w-[1px] h-full bg-gradient-to-b from-transparent via-[#e6394612] to-transparent opacity-80"></div>
    <div class="w-[1px] h-full bg-gradient-to-b from-transparent via-[#e6394612] to-transparent opacity-50"></div>
  </div>

  <CornerDecorations variant="light" />

  <div class="relative z-10 w-full max-w-6xl mx-auto">
    
    <div class="mb-12 flex flex-col items-start">
      <div class="flex items-center gap-4 mb-4">
        <span class="w-10 h-[2px] bg-[#e63946]"></span>
        <span class="text-xs font-semibold tracking-[0.3em] text-[#e63946]">CAREER</span>
      </div>
      <h2 class="text-4xl md:text-6xl font-light text-[#1a1a1a] leading-[1.1] mb-4">
        Work<br/>
        <span class="font-bold text-[#e63946]">Experience</span>
      </h2>
      <p class="text-lg text-[#666] font-normal">Professional journey and achievements</p>
    </div>

    <div class="grid grid-cols-1 gap-6">
      {experiences.map((exp) => (
        <div class="group relative bg-white border border-[#e5e5e5] overflow-hidden transition-all duration-300 hover:border-[#e63946]/30 hover:shadow-xl hover:shadow-[#e63946]/5">
          
          <!-- Red Accent Bar -->
          <div class="absolute top-0 left-0 w-1 h-full bg-[#e63946]"></div>
          
          <div class="p-6 md:p-8 pl-8 md:pl-10">
            <!-- Top Row -->
            <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-6">
              <div>
                <div class="flex items-center gap-3 mb-2">
                  <span class="text-xs font-mono text-[#e63946] bg-[#e63946]/10 px-2 py-1 tracking-wider">{exp.period}</span>
                  <span class="text-xs text-[#999] flex items-center gap-1">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    </svg>
                    {exp.location}
                  </span>
                </div>
                <h3 class="text-2xl md:text-3xl font-bold text-[#1a1a1a] mb-1 group-hover:text-[#e63946] transition-colors">{exp.role}</h3>
                <p class="text-base text-[#666] font-medium">{exp.company}</p>
              </div>
              
              <!-- Company Logo -->
              <div class="hidden md:flex w-16 h-16 bg-[#1a1a1a] items-center justify-center flex-shrink-0 overflow-hidden">
                {exp.logo ? (
                  <img src={exp.logo} alt={exp.company} class="w-full h-full object-cover" />
                ) : (
                  <span class="text-2xl font-bold text-white">{exp.company.charAt(0)}</span>
                )}
              </div>
            </div>

            <!-- Description -->
            <p class="text-[#666] leading-relaxed mb-6 max-w-3xl">
              {exp.description}
            </p>

            <!-- Bottom Row: Achievements + Tech -->
            <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 pt-6 border-t border-[#f0f0f0]">
              
              <!-- Achievements -->
              <div class="flex-1">
                <span class="text-xs font-semibold text-[#999] uppercase tracking-wider mb-3 block">Key Achievements</span>
                <ul class="flex flex-wrap gap-x-6 gap-y-2">
                  {exp.achievements.map((achievement) => (
                    <li class="flex items-center gap-2 text-sm text-[#555]">
                      <span class="w-1 h-1 bg-[#e63946] rounded-full"></span>
                      {achievement}
                    </li>
                  ))}
                </ul>
              </div>

              <!-- Technologies -->
              <div class="flex flex-wrap gap-2 lg:justify-end">
                {exp.technologies.map((tech) => (
                  <span class="px-3 py-1.5 text-xs font-medium text-[#555] bg-[#f5f5f5] border border-[#e5e5e5] transition-all duration-300 hover:border-[#e63946] hover:text-[#e63946]">
                    {tech}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
