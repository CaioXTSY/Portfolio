---
import BackgroundGrid from '../ui/BackgroundGrid.astro';
import CornerDecorations from '../ui/CornerDecorations.astro';
import ScrollIndicator from '../ui/ScrollIndicator.astro';
import { siteConfig } from '../../data/navigation';
---

<section id="home" class="w-full min-h-screen flex flex-col items-center justify-center gap-8 p-4 relative bg-white overflow-hidden snap-start sm:gap-12 sm:p-0">
  <BackgroundGrid variant="light" />
  <CornerDecorations variant="light" />
  <div class="flex flex-col items-center text-center relative z-10 sm:-ml-20">
    <div class="flex items-stretch justify-center">
      <span class="text-5xl font-black text-gray-900 tracking-tight leading-none sm:text-[8rem]">{siteConfig.firstName}</span>
      <span class="w-[3px] bg-red-500 ml-2 self-stretch relative sm:w-[5px] sm:ml-4">
        <span class="absolute -top-2 left-1/2 -translate-x-1/2 w-2 h-2 bg-red-500 rotate-45 sm:w-3 sm:h-3"></span>
        <span class="absolute -bottom-2 left-1/2 -translate-x-1/2 w-2 h-2 bg-red-500 rotate-45 sm:w-3 sm:h-3"></span>
      </span>
    </div>
    <span class="text-xl font-normal text-gray-500 tracking-[0.2em] uppercase mt-2 sm:text-[3.2rem] sm:tracking-[0.35em]">{siteConfig.lastName}</span>
  </div>
  <div class="flex flex-col items-center gap-6 relative z-10 sm:-ml-20">
    <div class="flex items-center gap-2 scale-75 sm:scale-100">
      <span class="w-1.5 h-1.5 bg-red-500/50 rounded-full"></span>
      <span class="w-5 h-px bg-red-500/40 sm:w-10"></span>
      <span class="w-px h-5 bg-red-500/60"></span>
      <span class="w-3 h-3 bg-red-500 rotate-45"></span>
      <span class="w-px h-5 bg-red-500/60"></span>
      <span class="w-5 h-px bg-red-500/40 sm:w-10"></span>
      <span class="w-1.5 h-1.5 bg-red-500/50 rounded-full"></span>
    </div>
    <div class="flex items-center gap-4">
      <span class="w-[30px] h-px bg-red-500/60"></span>
      <span class="text-xs font-medium text-gray-500 tracking-[0.15em] px-2 sm:text-base sm:tracking-[0.3em] lang-text" data-key="hero.title">{siteConfig.role}</span>
      <span class="w-[30px] h-px bg-red-500/60"></span>
    </div>
  </div>
  
  <div class="flex gap-3 relative z-10 sm:-ml-20">
    <button 
      data-lang="pt" 
      class="language-btn-mobile active px-3 py-1 text-sm font-semibold text-black transition-colors duration-300 border border-gray-300 rounded hover:border-[#e63946] hover:text-[#e63946]"
      title="Português"
    >
      PT
    </button>
    <button 
      data-lang="en" 
      class="language-btn-mobile px-3 py-1 text-sm font-semibold text-gray-400 transition-colors duration-300 border border-gray-300 rounded hover:border-[#e63946] hover:text-[#e63946]"
      title="English"
    >
      EN
    </button>
  </div>
  
  <ScrollIndicator />
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const languageBtnsMobile = document.querySelectorAll('.language-btn-mobile');
    const storedLang = localStorage.getItem('language') || 'pt';
    
    languageBtnsMobile.forEach(btn => {
      const lang = btn.getAttribute('data-lang');
      if (lang === storedLang) {
        btn.classList.add('active');
        btn.classList.remove('text-gray-400', 'border-gray-300');
        btn.classList.add('text-black', 'border-[#e63946]');
      } else {
        btn.classList.remove('active');
        btn.classList.add('text-gray-400', 'border-gray-300');
        btn.classList.remove('text-black', 'border-[#e63946]');
      }
      
      btn.addEventListener('click', () => {
        localStorage.setItem('language', lang || 'en');
        window.dispatchEvent(new CustomEvent('languageChange', { detail: lang }));
        
        languageBtnsMobile.forEach(b => {
          const bLang = b.getAttribute('data-lang');
          if (bLang === lang) {
            b.classList.add('active');
            b.classList.remove('text-gray-400', 'border-gray-300');
            b.classList.add('text-black', 'border-[#e63946]');
          } else {
            b.classList.remove('active');
            b.classList.add('text-gray-400', 'border-gray-300');
            b.classList.remove('text-black', 'border-[#e63946]');
          }
        });
      });
    });
  });
</script>
