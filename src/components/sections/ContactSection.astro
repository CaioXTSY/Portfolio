---
import { contactData } from '../../data/contact';
---

<section id="contact" class="w-full min-h-screen relative bg-[#0a0a0a] snap-start overflow-hidden flex flex-col">
  <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(230,57,70,0.03)_1px,transparent_1px),linear-gradient(0deg,rgba(230,57,70,0.03)_1px,transparent_1px)] bg-[size:60px_60px] pointer-events-none z-0"></div>

  <div class="flex-1 flex items-center justify-center py-20 px-4 md:px-8">
    <div class="relative z-10 w-full max-w-3xl mx-auto text-center">

      <div class="flex items-center justify-center gap-3 mb-8">
        <span class="w-8 h-[1px] bg-[#e63946]"></span>
        <span class="text-xs font-semibold tracking-[0.3em] text-[#e63946]">CONTACT</span>
        <span class="w-8 h-[1px] bg-[#e63946]"></span>
      </div>

      <h2 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight">
       Get In<br/>
        <span class="text-[#e63946]">Touch.</span>
      </h2>

      <p class="text-base md:text-lg text-[#666] mb-12 max-w-lg mx-auto">
       Have a project in mind? Let's talk. I'm always interested in hearing about new opportunities.
      </p>

      <a 
        href={`mailto:${contactData.email}`}
        class="group inline-flex items-center gap-4 px-8 py-5 bg-[#e63946] text-white text-lg font-semibold transition-all duration-300 hover:bg-[#c62b38] hover:gap-6"
      >
        <span>Say Hello</span>
        <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
        </svg>
      </a>

      <p class="mt-6 text-sm text-[#555]">
        or email me at <a href={`mailto:${contactData.email}`} class="text-[#888] hover:text-[#e63946] transition-colors underline underline-offset-4">{contactData.email}</a>
      </p>

      <div class="flex items-center justify-center gap-6 mt-16">
        {contactData.socials.map((social) => (
          <a 
            href={social.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center gap-2 text-[#666] hover:text-white transition-colors"
          >
            {social.icon === 'linkedin' && (
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            )}
            {social.icon === 'github' && (
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
            )}
            <span class="text-sm font-medium">{social.name}</span>
          </a>
        ))}
      </div>

    </div>
  </div>

  <footer class="relative z-10 border-t border-[#1a1a1a] py-8 px-4 md:px-8">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">

      <p class="text-sm text-[#555] md:w-1/3 text-center md:text-left">
        © {new Date().getFullYear()} <span class="text-[#888]">All rights reserved.</span>
      </p>

      <p class="text-xs text-[#444] md:w-1/3 text-center">
        Built with <span class="text-[#e63946]">Astro</span>
      </p>

      <a 
        href="#"
        class="flex items-center justify-center md:justify-end gap-2 text-sm text-[#555] hover:text-[#e63946] transition-colors md:w-1/3"
      >
        <span>Back to top</span>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"/>
        </svg>
      </a>

    </div>
  </footer>
</section>
