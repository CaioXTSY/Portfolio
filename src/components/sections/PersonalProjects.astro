---
import PersonalProjectCard from '../ui/PersonalProjectCard.astro';
import CarouselButton from '../ui/CarouselButton.astro';
import CornerDecorations from '../ui/CornerDecorations.astro';
import { personalProjects } from '../../data/projects';

const totalIndicators = Math.ceil(personalProjects.length / 1) || 2;
---

<section id="personal" class="relative w-full min-h-screen py-24 px-4 md:px-16 bg-[#0a0a0a] flex flex-col items-center justify-center overflow-hidden snap-start projects-section">
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#ffffff08_1px,transparent_1px),linear-gradient(to_bottom,#ffffff08_1px,transparent_1px)] bg-[size:80px_80px] pointer-events-none z-0"></div>

  <div class="absolute inset-0 pointer-events-none z-0 bg-[radial-gradient(ellipse_800px_400px_at_20%_50%,rgba(230,57,70,0.06)_0%,transparent_70%),radial-gradient(ellipse_600px_300px_at_80%_30%,rgba(230,57,70,0.03)_0%,transparent_70%)]">
    <CornerDecorations variant="dark" />
  </div>

  <div class="absolute top-0 left-0 right-0 h-[200px] bg-gradient-to-b from-[#0a0a0a] to-transparent z-10 pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 right-0 h-[200px] bg-gradient-to-t from-[#0a0a0a] to-transparent z-10 pointer-events-none"></div>

  <div class="flex flex-col items-center gap-4 mb-16 md:ml-[-80px] relative z-20">
    <h2 class="text-xl md:text-3xl font-semibold text-white tracking-[0.15em] md:tracking-[0.3em] relative [text-shadow:0_0_30px_rgba(230,57,70,0.2)] 
        before:content-['//'] before:hidden md:before:block before:absolute before:-left-10 before:text-[#e63946] before:font-normal before:opacity-50
        after:content-[''] after:hidden md:after:block after:absolute after:-bottom-2.5 after:left-1/2 after:-translate-x-1/2 after:w-[60%] after:h-[1px] after:bg-gradient-to-r after:from-transparent after:via-[#e6394650] after:to-transparent lang-text" data-key="projects.personal-section">
      PERSONAL PROJECTS
    </h2>
    <div class="flex items-center gap-2">
      <span class="w-[30px] h-[1px] bg-white/25 relative overflow-hidden after:content-[''] after:absolute after:top-0 after:-left-full after:w-full after:h-full after:bg-[#e63946] after:animate-[lineMove_2s_linear_infinite]"></span>
      <span class="w-2 h-2 bg-[#e63946] rotate-45 shadow-[0_0_10px_rgba(230,57,70,0.5)] animate-[diamondPulse_2s_ease-in-out_infinite]"></span>
      <span class="w-[30px] h-[1px] bg-white/25 relative overflow-hidden after:content-[''] after:absolute after:top-0 after:-left-full after:w-full after:h-full after:bg-[#e63946] after:animate-[lineMove_2s_linear_infinite]"></span>
    </div>
  </div>

  <div class="flex flex-col md:flex-row items-center gap-4 md:gap-8 w-full max-w-[1400px] md:ml-[-80px] relative z-20">
    <CarouselButton direction="prev" ariaLabel="Previous project" />
    
    <div class="flex-1 overflow-hidden py-8 w-full order-1 md:order-none">
      <div class="carousel-track flex gap-6 cursor-grab select-none active:cursor-grabbing">
        {personalProjects.map((project) => (
          <PersonalProjectCard project={project} />
        ))}
      </div>
    </div>
    
    <CarouselButton direction="next" ariaLabel="Next project" />
  </div>

  <div class="flex justify-center gap-3 mt-8 md:ml-[-80px] relative z-20">
    {Array.from({ length: totalIndicators }).map((_, index) => (
      <button 
        class={`indicator w-3 h-3 border-2 border-[#e63946]/50 bg-transparent rotate-45 p-0 relative transition-all duration-300 hover:border-[#e63946] hover:shadow-[0_0_10px_rgba(230,57,70,0.5)] [&.active]:bg-[#e63946] [&.active]:border-[#e63946] [&.active]:shadow-[0_0_15px_rgba(230,57,70,0.8)] ${index === 0 ? 'active' : ''}`}
        data-index={index}
      >
        <span class="absolute inset-[2px] bg-[#e63946] scale-0 transition-transform duration-300"></span>
      </button>
    ))}
  </div>
</section>

<style>
  @keyframes lineMove { 0% { left: -100%; } 100% { left: 200%; } }
  @keyframes diamondPulse { 0%, 100% { box-shadow: 0 0 10px rgba(230, 57, 70, 0.5); } 50% { box-shadow: 0 0 20px #e63946; } }
  .indicator.active span { transform: scale(1); }
</style>

<script>
  const track = document.querySelector('.carousel-track') as HTMLElement;
  const cards = Array.from(document.querySelectorAll('.project-card'));
  const prevBtn = document.querySelector('.carousel-btn.prev');
  const nextBtn = document.querySelector('.carousel-btn.next');
  const indicators = document.querySelectorAll('.indicator');
  
  const cardWidth = window.innerWidth < 768 ? 304 : 364;
  const totalCards = cards.length;
  let currentIndex = 0;
  let isTransitioning = false;
  
  function setupInfiniteCarousel() {
    if (!track || totalCards === 0) return;
    
    cards.forEach(card => {
      const clone = card.cloneNode(true) as HTMLElement;
      clone.classList.add('clone');
      track.appendChild(clone);
    });
    
    for (let i = cards.length - 1; i >= 0; i--) {
      const clone = cards[i].cloneNode(true) as HTMLElement;
      clone.classList.add('clone');
      track.insertBefore(clone, track.firstChild);
    }
    
    currentIndex = totalCards;
    track.style.transition = 'none';
    updatePosition();
  }
  
  function updatePosition() {
    if (!track) return;
    const offset = -currentIndex * cardWidth;
    track.style.transform = `translateX(${offset}px)`;
  }
  
  function updateIndicators() {
    const realIndex = ((currentIndex - totalCards) % totalCards + totalCards) % totalCards;
    indicators.forEach((ind, i) => {
      ind.classList.toggle('active', i === realIndex);
      const span = ind.querySelector('span') as HTMLElement;
      if (span) span.style.transform = i === realIndex ? 'scale(1)' : 'scale(0)';
    });
  }
  
  function goToSlide(index: number, smooth = true) {
    if (isTransitioning || !track) return;
    
    currentIndex = index;
    
    if (smooth) {
      track.style.transition = 'transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
      isTransitioning = true;
    } else {
      track.style.transition = 'none';
    }
    
    updatePosition();
    updateIndicators();
  }
  
  if (track) {
    track.addEventListener('transitionend', () => {
      isTransitioning = false;
      
      if (currentIndex >= totalCards * 2) {
        currentIndex = currentIndex - totalCards;
        track.style.transition = 'none';
        updatePosition();
      } else if (currentIndex < totalCards) {
        currentIndex = currentIndex + totalCards;
        track.style.transition = 'none';
        updatePosition();
      }
    });
  }
  
  prevBtn?.addEventListener('click', () => goToSlide(currentIndex - 1));
  nextBtn?.addEventListener('click', () => goToSlide(currentIndex + 1));
  
  indicators.forEach((indicator, i) => {
    indicator.addEventListener('click', () => {
      goToSlide(totalCards + i);
    });
  });

  let isDragging = false;
  let startX = 0;
  let dragStartIndex = 0;
  
  if (track) {
    track.addEventListener('mousedown', (e) => {
      isDragging = true;
      startX = e.pageX;
      dragStartIndex = currentIndex;
      track.style.cursor = 'grabbing';
      track.style.transition = 'none';
    });
    
    track.addEventListener('mousemove', (e) => {
      if (!isDragging) return;
      e.preventDefault();
      const x = e.pageX;
      const walk = startX - x;
      const offset = -(dragStartIndex * cardWidth + walk);
      track.style.transform = `translateX(${offset}px)`;
    });
    
    track.addEventListener('mouseup', (e) => {
      if (!isDragging) return;
      isDragging = false;
      track.style.cursor = 'grab';
      
      const walk = startX - e.pageX;
      const threshold = 100;
      
      if (walk > threshold) {
        goToSlide(currentIndex + 1);
      } else if (walk < -threshold) {
        goToSlide(currentIndex - 1);
      } else {
        goToSlide(currentIndex);
      }
    });
    
    track.addEventListener('mouseleave', () => {
      if (isDragging) {
        isDragging = false;
        track.style.cursor = 'grab';
        goToSlide(currentIndex);
      }
    });

    track.addEventListener('touchstart', (e) => {
      isDragging = true;
      startX = e.touches[0].pageX;
      dragStartIndex = currentIndex;
      track.style.transition = 'none';
    });

    track.addEventListener('touchmove', (e) => {
      if (!isDragging) return;
      const x = e.touches[0].pageX;
      const walk = startX - x;
      const offset = -(dragStartIndex * cardWidth + walk);
      track.style.transform = `translateX(${offset}px)`;
    });

    track.addEventListener('touchend', (e) => {
      if (!isDragging) return;
      isDragging = false;
      const walk = startX - (e.changedTouches[0]?.pageX || startX);
      const threshold = 50;
      if (walk > threshold) goToSlide(currentIndex + 1);
      else if (walk < -threshold) goToSlide(currentIndex - 1);
      else goToSlide(currentIndex);
    });
  }

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowLeft') goToSlide(currentIndex - 1);
    if (e.key === 'ArrowRight') goToSlide(currentIndex + 1);
  });
  
  setupInfiniteCarousel();
</script>
