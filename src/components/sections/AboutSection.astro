---
import { aboutData } from '../../data/about';
---

<section id="about" class="w-full min-h-screen relative bg-[#0a0a0a] snap-start overflow-hidden flex items-center justify-center py-20 px-4 md:px-8">
  <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(230,57,70,0.05)_1px,transparent_1px),linear-gradient(0deg,rgba(230,57,70,0.05)_1px,transparent_1px)] bg-[size:60px_60px] pointer-events-none z-0"></div>

  <div class="absolute top-6 left-6 w-12 h-12 border-l-2 border-t-2 border-[#e63946]/40 hidden md:block"></div>
  <div class="absolute top-6 right-6 w-12 h-12 border-r-2 border-t-2 border-[#e63946]/40 hidden md:block"></div>
  <div class="absolute bottom-6 left-6 w-12 h-12 border-l-2 border-b-2 border-[#e63946]/40 hidden md:block"></div>
  <div class="absolute bottom-6 right-6 w-12 h-12 border-r-2 border-b-2 border-[#e63946]/40 hidden md:block"></div>

  <div class="relative z-10 w-full max-w-5xl mx-auto">
    
    <div class="flex items-center gap-4 mb-16">
      <span class="w-12 h-[2px] bg-[#e63946]"></span>
      <span class="text-xs font-semibold tracking-[0.3em] text-[#e63946] uppercase">About</span>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
      
      <div class="lg:col-span-4">
        <div class="relative mb-8">
          <div class="aspect-square bg-[#111] overflow-hidden border border-[#222]">
            {aboutData.image ? (
              <img 
                src={aboutData.image} 
                alt={aboutData.name}
                class="w-full h-full object-cover"
              />
            ) : (
              <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-[#111] to-[#1a1a1a]">
                <span class="text-7xl font-bold text-[#e63946]/10">{aboutData.initials}</span>
              </div>
            )}
          </div>
          <div class="absolute -bottom-3 -right-3 w-full h-full border-2 border-[#e63946]/30 -z-10"></div>
        </div>

        <div class="space-y-4">
          {aboutData.basicInfo.map((info) => (
            <div class="flex justify-between items-center py-3 border-b border-[#222]">
              <span class="text-xs text-[#666] uppercase tracking-wider">{info.label}</span>
              <span class="text-sm font-medium text-white">{info.value}</span>
            </div>
          ))}
        </div>

        <a 
          href={aboutData.resumeUrl || '#contact'} 
          class="mt-8 w-full flex items-center justify-center gap-3 px-6 py-4 bg-[#e63946] text-white text-sm font-medium tracking-wide transition-all hover:bg-[#c62b38]"
        >
          <span>Download Resume</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
          </svg>
        </a>
      </div>
      
      <div class="lg:col-span-8">
        <div class="mb-8">
          <h2 class="text-4xl md:text-5xl font-bold text-white mb-2">{aboutData.name}</h2>
          <p class="text-lg text-[#e63946] font-medium">{aboutData.class}</p>
        </div>

        <p class="text-base md:text-lg text-[#999] leading-relaxed mb-10">
          {aboutData.bio}
        </p>
        
        <div class="mb-10">
          <h3 class="text-xs font-semibold text-[#666] uppercase tracking-wider mb-6">Technologies</h3>
          <div class="space-y-6">
            {aboutData.skills.map((skillGroup) => (
              <div>
                <h4 class="text-xs font-semibold text-[#999] uppercase tracking-wider mb-3">{skillGroup.category}</h4>
                <div class="flex flex-wrap gap-2">
                  {skillGroup.technologies.map((tech) => (
                    <span class="flex items-center gap-2 px-3 py-2 bg-[#111] border border-[#222] text-sm text-[#ccc] font-medium hover:border-[#e63946] hover:text-[#e63946] transition-colors">
                      {tech.icon && <span class="text-lg">{tech.icon}</span>}
                      <span>{tech.name}</span>
                    </span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {aboutData.archives.map((archive) => (
            <div class="p-6 bg-[#111] border border-[#222]">
              <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-3">{archive.title}</h4>
              <p class="text-sm text-[#888] leading-relaxed">{archive.content}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
