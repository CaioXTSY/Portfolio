---
import { aboutData } from '../../data/about';
---

<section id="about" class="w-full min-h-screen relative bg-[#0a0a0a] snap-start flex items-center py-24 px-4 md:px-8">
  <!-- Background Pattern -->
  <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(230,57,70,0.03)_1px,transparent_1px),linear-gradient(0deg,rgba(230,57,70,0.03)_1px,transparent_1px)] bg-[size:40px_40px] pointer-events-none z-0"></div>

  <div class="relative z-10 w-full max-w-6xl mx-auto">
    
    <!-- Header -->
    <div class="flex items-center gap-4 mb-12">
      <span class="w-12 h-[2px] bg-[#e63946]"></span>
      <span class="text-xs font-semibold tracking-[0.3em] text-[#e63946] uppercase lang-text" data-key="about.title">About</span>
    </div>

    <!-- Bento Grid Layout -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
      
      <!-- Main Bio Card (Span 8) -->
      <div class="md:col-span-8 bg-[#111] border border-[#222] p-8 md:p-10 relative group hover:border-[#e63946]/30 transition-colors duration-300">
        <div class="absolute top-0 right-0 p-4 opacity-20 group-hover:opacity-100 transition-opacity">
          <svg class="w-6 h-6 text-[#e63946]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
        </div>
        
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-2 lang-text" data-key="about.name">{aboutData.name}</h2>
        <p class="text-lg text-[#e63946] font-medium mb-6 lang-text" data-key="about.role">{aboutData.class}</p>
        
        <p class="text-[#999] leading-relaxed mb-8 text-base md:text-lg lang-text" data-key="about.bio">
          {aboutData.bio}
        </p>

        <a 
          href={aboutData.resumeUrl || '#contact'} 
          id="resume-link"
          class="inline-flex items-center gap-3 px-6 py-3 bg-[#e63946] text-white text-sm font-medium tracking-wide transition-all hover:bg-[#c62b38]"
        >
          <span class="lang-text" data-key="about.downloadResume">Download Resume</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
          </svg>
        </a>
      </div>

      <!-- Stats/Info Card (Span 4) -->
      <div class="md:col-span-4 bg-[#111] border border-[#222] p-8 md:p-10 flex flex-col justify-center hover:border-[#e63946]/30 transition-colors duration-300">
        <div class="space-y-6">
          {aboutData.basicInfo.map((info) => (
            <div class="group/item">
              <span class="block text-xs text-[#666] uppercase tracking-wider mb-1 group-hover/item:text-[#e63946] transition-colors lang-text" data-key={`about.${info.label.toLowerCase()}`}>{info.label}</span>
              <span class="block text-lg font-medium text-white lang-text" data-key={`about.${info.label.toLowerCase()}Value`}>{info.value}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Tech Stack (Span 7) -->
      <div class="md:col-span-7 bg-[#111] border border-[#222] p-8 md:p-10 hover:border-[#e63946]/30 transition-colors duration-300">
        <h3 class="text-sm font-semibold text-[#e63946] uppercase tracking-wider mb-6 flex items-center gap-2">
          <span class="lang-text" data-key="about.technologies">Technologies</span>
          <span class="h-px flex-1 bg-[#222]"></span>
        </h3>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
          {aboutData.skills.map((skillGroup) => (
            <div>
              <h4 class="text-xs font-semibold text-[#666] uppercase tracking-wider mb-4 lang-text" data-key={`about.${skillGroup.category.toLowerCase()}`}>{skillGroup.category}</h4>
              <div class="flex flex-wrap gap-2">
                {skillGroup.technologies.map((tech) => (
                  <span class="px-3 py-1.5 bg-[#1a1a1a] text-sm text-[#ccc] border border-[#222] hover:border-[#e63946]/50 hover:text-white transition-colors cursor-default">
                    {tech.name}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Focus/Archives (Span 5) -->
      <div class="md:col-span-5 bg-[#111] border border-[#222] p-8 md:p-10 flex flex-col justify-between gap-6 hover:border-[#e63946]/30 transition-colors duration-300">
        {aboutData.archives.map((archive, index) => (
          <div class={index !== aboutData.archives.length - 1 ? "border-b border-[#222] pb-6" : ""}>
            <div class="flex items-center justify-between mb-2">
              <h4 class="text-white font-medium lang-text" data-key={`about.${archive.title.includes('Design') ? 'design' : 'devops'}`}>{archive.title}</h4>
              <svg class="w-4 h-4 text-[#333]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
            </div>
            <p class="text-sm text-[#888] lang-text" data-key={`about.${archive.title.includes('Design') ? 'designDesc' : 'devopsDesc'}`}>{archive.content}</p>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>