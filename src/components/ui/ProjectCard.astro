---
import type { Project } from '../../types';
import TechBadge from '../ui/TechBadge.astro';
import ArrowIcon from '../ui/ArrowIcon.astro';

interface Props {
  project: Project;
  featured?: boolean;
}

const { project, featured = false } = Astro.props;
---

<article class={`group relative bg-white rounded-sm overflow-hidden border border-[#e5e5e5] transition-all duration-400 ease-[cubic-bezier(0.4,0,0.2,1)] cursor-pointer hover:-translate-y-1 hover:shadow-[0_20px_40px_rgba(0,0,0,0.08)] hover:border-[#e6394630] ${featured ? 'lg:row-span-2' : ''}`}>
  <div class="absolute top-0 left-0 h-[3px] bg-[#e63946] w-0 transition-all duration-400 ease-out group-hover:w-full z-20"></div>
  <div class="absolute inset-0 bg-gradient-to-br from-transparent to-[#e6394605] opacity-0 transition-opacity duration-400 ease-out group-hover:opacity-100"></div>
  
  <div class={`relative ${featured ? 'p-8 lg:p-10' : 'p-8'} h-full flex flex-col z-10`}>
    <div class="flex justify-between items-center mb-6">
      <span class="text-sm font-semibold text-[#999] font-inter">{project.year}</span>
      <span class="text-[0.7rem] font-semibold tracking-wider text-[#e63946] bg-[#e6394610] px-3 py-1.5 rounded-[1px] uppercase">
        {project.category}
      </span>
    </div>

    <h3 class={`${featured ? 'text-2xl lg:text-3xl' : 'text-2xl'} font-semibold text-[#1a1a1a] mb-3 transition-colors duration-300 group-hover:text-[#e63946]`}>
      {project.title}
    </h3>

    <p class={`${featured ? 'text-base' : 'text-sm'} text-[#666] leading-relaxed mb-6 flex-grow`}>
      {project.description}
    </p>

    <div class="flex flex-wrap gap-2 mb-6">
      {project.techStack.map((tech) => (
        <TechBadge text={tech} variant="light" />
      ))}
    </div>
    
    </div>
  </div>
</article>
