---
import type { TechCategory } from '../../types';
import IconBox from './IconBox.astro';

interface Props {
  category: TechCategory;
}

const { category } = Astro.props;
---

<div class="group relative bg-[#111] border border-[#e6394630] p-8 transition-all duration-400 ease-[cubic-bezier(0.4,0,0.2,1)] hover:border-[#e63946] hover:-translate-y-2 hover:shadow-[0_20px_40px_rgba(230,57,70,0.15)]">
  <div class="absolute w-[15px] h-[15px] border-2 border-[#e63946] -top-[1px] -left-[1px] border-r-0 border-b-0 transition-all duration-300 group-hover:w-[25px] group-hover:h-[25px]"></div>
  <div class="absolute w-[15px] h-[15px] border-2 border-[#e63946] -top-[1px] -right-[1px] border-l-0 border-b-0 transition-all duration-300 group-hover:w-[25px] group-hover:h-[25px]"></div>
  <div class="absolute w-[15px] h-[15px] border-2 border-[#e63946] -bottom-[1px] -left-[1px] border-r-0 border-t-0 transition-all duration-300 group-hover:w-[25px] group-hover:h-[25px]"></div>
  <div class="absolute w-[15px] h-[15px] border-2 border-[#e63946] -bottom-[1px] -right-[1px] border-l-0 border-t-0 transition-all duration-300 group-hover:w-[25px] group-hover:h-[25px]"></div>
  <div class="absolute top-0 right-0 w-[60px] h-full pointer-events-none bg-[repeating-linear-gradient(-45deg,transparent,transparent_5px,rgba(230,57,70,0.03)_5px,rgba(230,57,70,0.03)_10px)]"></div>
  
  <div class="flex items-center gap-4 mb-8 pb-4 border-b border-[#e6394620] relative">
    <span class="text-xs text-[#e63946] font-bold tracking-widest">{category.number}</span>
    <h3 class="text-base font-bold text-white tracking-[0.15em] flex-grow">{category.title}</h3>
    <span class="w-2 h-2 bg-[#e63946] rounded-full animate-[stackPulse_2s_ease-in-out_infinite]"></span>
  </div>
  
  <div class="grid grid-cols-3 gap-6">
    {category.items.map((item) => (
      <IconBox icon={item.icon} />
    ))}
  </div>
</div>

<style>
  @keyframes stackPulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }
</style>
