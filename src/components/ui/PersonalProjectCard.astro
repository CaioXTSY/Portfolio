---
import type { Project } from '../../types';
import TechBadge from '../ui/TechBadge.astro';

interface Props {
  project: Project;
}

const { project } = Astro.props;

const backgroundStyle = project.image 
  ? project.image.startsWith('linear-gradient') 
    ? `background: ${project.image};` 
    : `background-image: url(${project.image}); background-size: cover; background-position: center;`
  : 'background: linear-gradient(135deg, #450a0a 0%, #dc2626 100%);';
---

<div class="project-card group w-[280px] md:w-[340px] shrink-0 bg-[#111] border border-[#222] border-l-4 border-l-transparent transition-all duration-400 ease-[cubic-bezier(0.4,0,0.2,1)] cursor-pointer relative overflow-hidden 
    hover:border-l-[#e63946] hover:-translate-y-2 hover:scale-[1.02] hover:bg-[#151515] hover:shadow-[0_8px_32px_rgba(230,57,70,0.2),0_0_0_1px_rgba(230,57,70,0.2),inset_0_1px_0_rgba(230,57,70,0.1)]">
  
  <div class="absolute inset-0 opacity-50 pointer-events-none bg-[repeating-linear-gradient(90deg,transparent,transparent_20px,rgba(255,255,255,0.02)_20px,rgba(255,255,255,0.02)_21px)]"></div>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_0%,rgba(230,57,70,0.08)_0%,transparent_60%)] opacity-0 transition-opacity duration-400 ease-out group-hover:opacity-100"></div>
  <div class="absolute top-0 left-0 right-0 h-[2px] bg-gradient-to-r from-transparent via-[#e63946] to-transparent scale-x-0 transition-transform duration-400 ease-out group-hover:scale-x-100"></div>
  
  <div class="w-full h-[140px] md:h-[180px] bg-[#1a1a1a] bg-cover bg-center" style={backgroundStyle}></div>
  
  <div class="relative z-10 p-4 md:p-6 flex flex-col gap-3">
    <div class="flex justify-between items-start">
      <span class="text-xs text-gray-500 font-medium tracking-wide font-inter group-hover:text-[#e63946] transition-colors">{project.category}</span>
      <span class="w-3 h-3 rounded-full bg-[#333] shrink-0 group-hover:bg-[#e63946] group-hover:shadow-[0_0_12px_rgba(230,57,70,0.5)] transition-colors"></span>
    </div>
    
    <h4 class="text-xl md:text-2xl font-bold text-white font-inter leading-tight tracking-tight group-hover:text-[#e63946] transition-colors" data-key={`projects.${project.id}`}>
      {project.title}
    </h4>
    
    <p class="text-sm text-gray-400 leading-relaxed font-inter font-normal" data-key={`projects.${project.id}Desc`}>
      {project.description}
    </p>
    
    <div class="flex flex-col gap-2 mt-1">
      <span class="text-[10px] font-semibold text-gray-500 tracking-widest font-inter uppercase">TECH STACK:</span>
      <div class="flex flex-wrap gap-2">
        {project.techStack.map((tech) => (
          <TechBadge text={tech} variant="dark" />
        ))}
      </div>
    </div>
  </div>
</div>
