---
import type { Project } from '../../types';
import TechBadge from '../ui/TechBadge.astro';

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<div class="project-card group w-[280px] md:w-[340px] shrink-0 bg-[#111] border border-[#222] transition-all duration-300 cursor-pointer relative overflow-hidden flex flex-col
    hover:border-[#e63946]/30 hover:-translate-y-1 hover:shadow-[0_8px_32px_rgba(230,57,70,0.15)]">

  <!-- Top accent line on hover -->
  <div class="absolute top-0 left-0 right-0 h-[2px] bg-gradient-to-r from-transparent via-[#e63946] to-transparent scale-x-0 transition-transform duration-300 ease-out group-hover:scale-x-100 z-10"></div>

  <!-- Image area with letter fallback -->
  <div class="relative w-full h-[160px] bg-[#1a1a1a] shrink-0 overflow-hidden">
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
      <span class="text-6xl font-black text-[#2a2a2a] select-none">{project.title.charAt(0)}</span>
    </div>
    {project.image && (
      <img
        src={project.image}
        alt={project.title}
        class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
      />
    )}
    <div class="absolute inset-0 bg-gradient-to-t from-[#111] via-transparent to-transparent opacity-50"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 p-5 flex flex-col gap-3 flex-1">
    <div class="flex items-start justify-between gap-2">
      <h4
        class="text-lg font-bold text-white leading-tight tracking-tight group-hover:text-[#e63946] transition-colors duration-300"
        data-key={`projects.${project.id}`}
      >
        {project.title}
      </h4>
      <span class="text-xs text-[#555] font-medium shrink-0 pt-0.5">{project.year}</span>
    </div>

    <p
      class="text-sm text-gray-400 leading-relaxed line-clamp-3"
      data-key={`projects.${project.id}Desc`}
    >
      {project.description}
    </p>

    <div class="flex flex-wrap gap-1.5 mt-auto pt-3 border-t border-[#1e1e1e]">
      {project.techStack.map((tech) => (
        <TechBadge text={tech} variant="dark" />
      ))}
    </div>
  </div>
</div>
