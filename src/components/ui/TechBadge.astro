---
interface Props {
  text: string;
  variant?: 'dark' | 'light';
  interactive?: boolean;
}

const { text, variant = 'dark', interactive = true } = Astro.props;

const isDark = variant === 'dark';

const baseClasses = 'text-xs px-3 py-1.5 font-medium transition-all duration-200';
const darkClasses = 'border border-[#333] bg-transparent text-gray-400';
const lightClasses = 'bg-[#f5f5f5] text-[#666] rounded-[1px]';
const hoverClasses = interactive 
  ? isDark 
    ? 'group-hover:bg-[#e63946] group-hover:border-[#e63946] group-hover:text-white'
    : 'group-hover:bg-[#e63946] group-hover:text-white'
  : '';
---

<span class={`${baseClasses} ${isDark ? darkClasses : lightClasses} ${hoverClasses}`}>
  {text}
</span>
