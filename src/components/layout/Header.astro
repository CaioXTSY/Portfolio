---
import { navigationItems, siteConfig } from '../../data/navigation';
---

<header class="header-wrapper group/header fixed left-0 top-0 h-screen w-[50px] z-[1000] sm:w-20 max-[480px]:hidden">
  <!-- Camada de fundo clara -->
  <div class="absolute inset-0 bg-white border-r border-gray-100 transition-opacity duration-500 ease-out group-[.dark]/header:opacity-0"></div>
  <!-- Camada de fundo escura -->
  <div class="absolute inset-0 bg-[#0a0a0a] border-r border-[#1a1a1a] opacity-0 transition-opacity duration-500 ease-out group-[.dark]/header:opacity-100"></div>
  
  <!-- Conteúdo -->
  <div class="relative h-full flex flex-col justify-between items-center py-4 sm:py-8">
    <div class="[writing-mode:vertical-rl] [text-orientation:mixed] rotate-180">
      <a href="/" class="flex gap-2 text-[0.65rem] font-bold tracking-[0.15em] text-black no-underline sm:text-[0.85rem] transition-colors duration-500 ease-out group-[.dark]/header:text-white">
        <span>{siteConfig.firstName}</span>
        <span class="font-normal">{siteConfig.lastName}</span>
      </a>
    </div>
    
    <nav class="flex-1 flex items-center">
      <ul class="list-none p-0 m-0 flex flex-col gap-3 items-center sm:gap-6">
        {navigationItems.map((item, index) => (
          <li class={`nav-item group ${index === 0 ? 'active' : ''}`} data-nav-id={item.id}>
            <a 
              href={item.href} 
              class="flex flex-col items-center gap-2 no-underline text-gray-400 transition-colors duration-500 ease-out hover:text-black group-[.active]:text-black group-[.dark]/header:text-gray-500 group-[.dark]/header:hover:text-white group-[.active]:group-[.dark]/header:text-white"
            >
              <span class="text-[0.6rem] font-semibold tracking-[0.05em] sm:text-xs">{item.number}</span>
              <span class="w-0.5 h-3 bg-gray-200 transition-all duration-300 group-hover:bg-[#e63946] group-[.active]:bg-[#e63946] group-[.active]:h-5 sm:h-5 sm:group-[.active]:h-[30px] group-[.dark]/header:bg-gray-700"></span>
            </a>
          </li>
        ))}
      </ul>
    </nav>

    {siteConfig.availableForWork && (
      <div class="flex items-center gap-1.5 [writing-mode:vertical-rl] [text-orientation:mixed] rotate-180 sm:gap-2">
        <span class="w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse sm:w-2 sm:h-2"></span>
        <span class="text-[0.55rem] font-semibold tracking-[0.15em] text-green-500 sm:text-[0.65rem]">AVAILABLE</span>
      </div>
    )}
  </div>
</header>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const header = document.querySelector('.header-wrapper');
    const navItems = document.querySelectorAll('.nav-item');
    const sections = document.querySelectorAll('section[id]');

    // Seções com fundo escuro
    const darkSections = ['about', 'experience', 'contact'];

    const observerOptions = {
      root: null,
      rootMargin: '-30% 0px -70% 0px',
      threshold: 0
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const section = entry.target as HTMLElement;
          const id = section.getAttribute('id');
          
          // Verifica se a seção é escura
          const isDarkSection = (id && darkSections.includes(id)) || 
            section.classList.contains('bg-[#0a0a0a]');
          
          if (isDarkSection) {
            header?.classList.add('dark');
          } else {
            header?.classList.remove('dark');
          }

          // Atualiza navegação ativa
          if (id) {
            navItems.forEach((item) => {
              item.classList.remove('active');
            });
            
            const activeLink = document.querySelector(`.nav-item a[href="#${id}"]`);
            if (activeLink) {
              activeLink.closest('.nav-item')?.classList.add('active');
            }
          }
        }
      });
    }, observerOptions);

    sections.forEach(section => observer.observe(section));

    // Smooth scroll ao clicar nos links
    navItems.forEach(item => {
      const link = item.querySelector('a');
      link?.addEventListener('click', (e) => {
        e.preventDefault();
        const href = link.getAttribute('href');
        if (href && href.startsWith('#')) {
          const targetId = href.substring(1);
          const targetSection = document.getElementById(targetId);
          
          if (targetSection) {
            targetSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        }
      });
    });
  });
</script>
