---
import '../styles/global.css';
import Layout from '../layouts/Layout.astro';
---

<Layout title="Caio Teixeira | Portfolio">
	<main>
		<!-- Background decorations -->
		<div class="bg-grid"></div>
		<div class="bg-decorations">
			<!-- Corners -->
			<div class="corner corner-tl"></div>
			<div class="corner corner-tr"></div>
			<div class="corner corner-bl"></div>
			<div class="corner corner-br"></div>
		</div>

		<div class="name-container">
			<div class="name-row">
				<span class="first-name">CAIO</span>
				<span class="divider"></span>
			</div>
			<span class="last-name">TEIXEIRA</span>
		</div>

		<div class="info-section">
			<div class="decoration-line">
				<span class="dot"></span>
				<span class="line"></span>
				<span class="line-vertical"></span>
				<span class="diamond"></span>
				<span class="line-vertical"></span>
				<span class="line"></span>
				<span class="dot"></span>
			</div>

			<div class="role">
				<span class="role-line"></span>
				<span class="role-text">FULLSTACK DEVELOPER</span>
				<span class="role-line"></span>
			</div>

			<div class="status-row">
				<div class="status-item">
					<span class="status-dot available"></span>
					<span class="status-text">AVAILABLE</span>
				</div>
				<span class="status-diamond"></span>
				<div class="status-item">
					<span class="status-dot location"></span>
					<span class="status-text">BRAZIL</span>
				</div>
			</div>
		</div>

		<div class="scroll-indicator">
			<div class="scroll-line"></div>
			<div class="scroll-dot"></div>
			<span class="scroll-text">SCROLL</span>
		</div>
	</main>

	<section class="projects-section">
		<div class="section-header">
			<h2 class="section-title">PROJECTS</h2>
			<div class="section-decoration">
				<span class="section-line"></span>
				<span class="section-diamond"></span>
				<span class="section-line"></span>
			</div>
		</div>

		<!-- Personal Projects -->
		<div class="projects-category">
			<div class="category-header">
				<span class="category-line"></span>
				<h3 class="category-title">PERSONAL PROJECTS</h3>
			</div>

			<div class="projects-grid">
				<div class="project-card">
					<div class="card-stripes"></div>
					<div class="card-image" style="background-color: #e0e7ff;"></div>
					<div class="card-content">
						<div class="project-card-header">
							<span class="project-label">Lorem API</span>
							<span class="project-indicator"></span>
						</div>
						<h4 class="project-name">Lorem API Dashboard</h4>
						<p class="project-description">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt.</p>

						<div class="project-tags">
							<span class="tags-label">TECH STACK:</span>
							<div class="tags-list">
								<span class="tag">NestJS</span>
								<span class="tag">TypeScript</span>
								<span class="tag">PostgreSQL</span>
							</div>
						</div>

						<div class="project-status">
							<span class="status-dot completed"></span>
							<span class="status-label">COMPLETED</span>
						</div>
					</div>
				</div>

				<div class="project-card">
					<div class="card-stripes"></div>
					<div class="card-image" style="background-color: #f0fdf4;"></div>
					<div class="card-content">
						<div class="project-card-header">
							<span class="project-label">Ipsum</span>
							<span class="project-indicator"></span>
						</div>
						<h4 class="project-name">Ipsum AI Interface</h4>
						<p class="project-description">Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip.</p>

						<div class="project-tags">
							<span class="tags-label">TECH STACK:</span>
							<div class="tags-list">
								<span class="tag">React</span>
								<span class="tag">Node.js</span>
							</div>
						</div>

						<div class="project-status">
							<span class="status-dot active"></span>
							<span class="status-label">ACTIVE</span>
						</div>
					</div>
				</div>

				<div class="project-card">
					<div class="card-stripes"></div>
					<div class="card-image" style="background-color: #fef2f2;"></div>
					<div class="card-content">
						<div class="project-card-header">
							<span class="project-label">Dolor API</span>
							<span class="project-indicator"></span>
						</div>
						<h4 class="project-name">Dolor PDF Processing</h4>
						<p class="project-description">Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore.</p>

						<div class="project-tags">
							<span class="tags-label">TECH STACK:</span>
							<div class="tags-list">
								<span class="tag">Python</span>
								<span class="tag">FastAPI</span>
							</div>
						</div>

						<div class="project-status">
							<span class="status-dot completed"></span>
							<span class="status-label">COMPLETED</span>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>

<style>
	main {
		width: 100%;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 3rem;
		position: relative;
		background-color: #ffffff;
		overflow: hidden;
		scroll-snap-align: start;
	}

	/* Background Grid */
	.bg-grid {
		position: absolute;
		inset: 0;
		background-image: 
			linear-gradient(to right, #e0e0e040 1px, transparent 1px),
			linear-gradient(to bottom, #e0e0e040 1px, transparent 1px);
		background-size: 80px 80px;
		pointer-events: none;
		z-index: 0;
	}

	/* Background Decorations */
	.bg-decorations {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 0;
	}

	/* Corners */
	.corner {
		position: absolute;
		width: 60px;
		height: 60px;
		border-color: #e6394640;
		border-style: solid;
		border-width: 0;
	}

	.corner-tl {
		top: 20px;
		left: 20px;
		border-top-width: 1px;
		border-left-width: 1px;
	}

	.corner-tr {
		top: 20px;
		right: 20px;
		border-top-width: 1px;
		border-right-width: 1px;
	}

	.corner-bl {
		bottom: 20px;
		left: 20px;
		border-bottom-width: 1px;
		border-left-width: 1px;
	}

	.corner-br {
		bottom: 20px;
		right: 20px;
		border-bottom-width: 1px;
		border-right-width: 1px;
	}

	.name-container {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		position: relative;
		z-index: 1;
	}

	.name-row {
		display: flex;
		align-items: stretch;
		justify-content: center;
	}

	.first-name {
		font-size: 8rem;
		font-weight: 900;
		color: #1a1a1a;
		letter-spacing: -0.02em;
		line-height: 1;
	}

	.divider {
		width: 5px;
		background-color: #e63946;
		margin-left: 1rem;
		align-self: stretch;
	}

	.last-name {
		font-size: 3.2rem;
		font-weight: 400;
		color: #666;
		letter-spacing: 0.35em;
		text-transform: uppercase;
		margin-top: 0.5rem;
	}

	.info-section {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.5rem;
		position: relative;
		z-index: 1;
	}

	.decoration-line {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.dot {
		width: 6px;
		height: 6px;
		background-color: #e6394650;
		border-radius: 50%;
	}

	.line {
		width: 40px;
		height: 1px;
		background: linear-gradient(90deg, #e6394630, #e6394680);
	}

	.line-vertical {
		width: 1px;
		height: 20px;
		background-color: #e6394660;
	}

	.diamond {
		width: 12px;
		height: 12px;
		background-color: #e63946;
		transform: rotate(45deg);
		animation: pulse-diamond 2s ease-in-out infinite;
	}

	@keyframes pulse-diamond {
		0%, 100% {
			transform: rotate(45deg) scale(1);
			opacity: 1;
		}
		50% {
			transform: rotate(45deg) scale(1.1);
			opacity: 0.8;
		}
	}

	.role {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.role-line {
		width: 30px;
		height: 1px;
		background-color: #e6394660;
	}

	.role-text {
		font-size: 1rem;
		font-weight: 500;
		color: #888;
		letter-spacing: 0.3em;
	}

	.status-row {
		display: flex;
		align-items: center;
		gap: 2rem;
	}

	.status-item {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.status-dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
	}

	.status-dot.available {
		background-color: #22c55e;
		animation: pulse-dot 2s ease-in-out infinite;
	}

	.status-dot.location {
		background-color: #e63946;
	}

	@keyframes pulse-dot {
		0%, 100% {
			box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.4);
		}
		50% {
			box-shadow: 0 0 0 6px rgba(34, 197, 94, 0);
		}
	}

	.status-text {
		font-size: 0.85rem;
		font-weight: 500;
		color: #888;
		letter-spacing: 0.15em;
	}

	.status-diamond {
		width: 6px;
		height: 6px;
		background-color: #e6394650;
		transform: rotate(45deg);
	}

	.scroll-indicator {
		position: absolute;
		bottom: 2rem;
		left: 50%;
		transform: translateX(-50%);
		display: flex;
		z-index: 1;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
	}

	.scroll-line {
		width: 1px;
		height: 50px;
		background: linear-gradient(180deg, #e6394680, #e6394620);
	}

	.scroll-dot {
		width: 8px;
		height: 8px;
		background-color: #e63946;
		border-radius: 50%;
		animation: scroll-bounce 1.5s ease-in-out infinite;
	}

	@keyframes scroll-bounce {
		0%, 100% {
			transform: translateY(0);
			opacity: 1;
		}
		50% {
			transform: translateY(8px);
			opacity: 0.5;
		}
	}

	.scroll-text {
		font-size: 0.7rem;
		font-weight: 500;
		color: #666;
		letter-spacing: 0.2em;
		margin-top: 0.25rem;
	}

	@media (max-width: 768px) {
		main {
			gap: 2rem;
		}

		.first-name {
			font-size: 4rem;
		}

		.divider {
			width: 3px;
			margin-left: 0.5rem;
		}

		.last-name {
			font-size: 1.8rem;
			letter-spacing: 0.25em;
		}

		.line {
			width: 20px;
		}

		.role-text {
			font-size: 0.8rem;
			letter-spacing: 0.2em;
		}

		.status-row {
			gap: 1rem;
		}

		.status-text {
			font-size: 0.75rem;
		}
	}

	/* Projects Section */
	.projects-section {
		width: 100%;
		min-height: 100vh;
		padding: 6rem 4rem;
		background-color: #fafafa;
		display: flex;
		flex-direction: column;
		align-items: center;
		scroll-snap-align: start;
	}

	.section-header {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
		margin-bottom: 4rem;
	}

	.section-title {
		font-size: 2rem;
		font-weight: 600;
		color: #1a1a1a;
		letter-spacing: 0.3em;
	}

	.section-decoration {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.section-line {
		width: 30px;
		height: 1px;
		background-color: #1a1a1a;
	}

	.section-diamond {
		width: 8px;
		height: 8px;
		background-color: #e63946;
		transform: rotate(45deg);
	}

	/* Projects Category */
	.projects-category {
		width: 100%;
		max-width: 1200px;
	}

	.category-header {
		display: flex;
		align-items: center;
		gap: 1rem;
		margin-bottom: 2rem;
	}

	.category-line {
		width: 4px;
		height: 20px;
		background-color: #e63946;
	}

	.category-title {
		font-size: 0.9rem;
		font-weight: 600;
		color: #1a1a1a;
		letter-spacing: 0.2em;
	}

	.projects-grid {
		width: 100%;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem;
	}

	/* Project Card */
	.project-card {
		background-color: #fff;
		border: 1px solid #e5e7eb;
		border-left: 4px solid transparent;
		transition: all 0.2s ease;
		cursor: pointer;
		position: relative;
		overflow: hidden;
	}

	.project-card:hover,
	.project-card:focus {
		border-left-color: #3b82f6;
		box-shadow: 0 4px 20px rgba(59, 130, 246, 0.15);
	}

	/* Card Stripes Background */
	.card-stripes {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background-image: repeating-linear-gradient(
			90deg,
			transparent,
			transparent 20px,
			#f8fafc 20px,
			#f8fafc 21px
		);
		pointer-events: none;
		opacity: 0.5;
	}

	/* Card Image */
	.card-image {
		width: 100%;
		height: 180px;
		background-color: #f3f4f6;
		background-size: cover;
		background-position: center;
	}

	.card-content {
		position: relative;
		z-index: 1;
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.project-card-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
	}

	.project-label {
		font-size: 0.75rem;
		color: #9ca3af;
		font-family: 'Inter', system-ui, sans-serif;
		font-weight: 500;
		letter-spacing: 0.05em;
	}

	.project-card:hover .project-label {
		color: #3b82f6;
	}

	.project-indicator {
		width: 12px;
		height: 12px;
		border-radius: 50%;
		background-color: #e5e7eb;
		flex-shrink: 0;
	}

	.project-card:hover .project-indicator {
		background-color: #3b82f6;
	}

	.project-name {
		font-size: 1.5rem;
		font-weight: 700;
		color: #1a1a1a;
		font-family: 'Inter', system-ui, sans-serif;
		line-height: 1.3;
		letter-spacing: -0.01em;
	}

	.project-card:hover .project-name {
		color: #3b82f6;
	}

	.project-description {
		font-size: 0.875rem;
		color: #6b7280;
		line-height: 1.6;
		font-family: 'Inter', system-ui, sans-serif;
		font-weight: 400;
	}

	.project-tags {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		margin-top: 0.25rem;
	}

	.tags-label {
		font-size: 0.625rem;
		font-weight: 600;
		color: #9ca3af;
		letter-spacing: 0.1em;
		font-family: 'Inter', system-ui, sans-serif;
		text-transform: uppercase;
	}

	.tags-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.tag {
		font-size: 0.75rem;
		padding: 0.375rem 0.75rem;
		border: 1.5px solid #1f2937;
		background-color: transparent;
		color: #1f2937;
		font-weight: 500;
		transition: all 0.2s ease;
		font-family: 'Inter', system-ui, sans-serif;
	}

	.project-card:hover .tag {
		background-color: #3b82f6;
		border-color: #3b82f6;
		color: #fff;
	}

	.project-status {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 0.5rem;
		margin-top: auto;
		padding-top: 1rem;
	}

	.project-status .status-dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
	}

	.project-status .status-dot.completed {
		background-color: #3b82f6;
	}

	.project-status .status-dot.active {
		background-color: #22c55e;
	}

	.project-status .status-dot.in-progress {
		background-color: #f59e0b;
	}

	.status-label {
		font-size: 0.75rem;
		font-weight: 500;
		color: #6b7280;
		letter-spacing: 0.025em;
	}

	@media (max-width: 1024px) {
		.projects-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 768px) {
		.projects-section {
			padding: 4rem 2rem;
		}

		.section-title {
			font-size: 1.5rem;
			letter-spacing: 0.2em;
		}

		.projects-grid {
			grid-template-columns: 1fr;
		}

		.category-title {
			font-size: 0.8rem;
		}
	}
</style>