	.section-title {
		font-size: 2rem;
		font-weight: 600;
		color: #ffffff;
		letter-spacing: 0.3em;
		position: relative;
		text-shadow: 0 0 30px #e6394630;
	}

	.section-title::before {
		content: '//';
		position: absolute;
		left: -40px;
		color: #e63946;
		font-weight: 400;
		opacity: 0.5;
	}

	.section-title::after {
		content: '';
		position: absolute;
		bottom: -10px;
		left: 50%;
		transform: translateX(-50%);
		width: 60%;
		height: 1px;
		background: linear-gradient(90deg, transparent, #e6394650, transparent);
	}

	.section-decoration {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.section-line {
		width: 30px;
		height: 1px;
		background-color: #ffffff40;
		position: relative;
		overflow: hidden;
	}

	.section-line::after {
		content: '';
		position: absolute;
		top: 0;
		left: -100%;
		width: 100%;
		height: 100%;
		background: #e63946;
		animation: section-line-move 2s linear infinite;
	}

	@keyframes section-line-move {
		0% { left: -100%; }
		100% { left: 200%; }
	}

	.section-diamond {
		width: 8px;
		height: 8px;
		background-color: #e63946;
		transform: rotate(45deg);
		box-shadow: 0 0 10px #e6394680;
		animation: section-diamond-pulse 2s ease-in-out infinite;
	}

	@keyframes section-diamond-pulse {
		0%, 100% { box-shadow: 0 0 10px #e6394680; }
		50% { box-shadow: 0 0 20px #e63946; }
