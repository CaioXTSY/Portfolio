	/* Corners */
	.corner {
		position: absolute;
		width: 60px;
		height: 60px;
		border-color: #e6394640;
		border-style: solid;
		border-width: 0;
	}

	.corner-tl {
		top: 20px;
		left: 20px;
		border-top-width: 1px;
		border-left-width: 1px;
	}

	.corner-tr {
		top: 20px;
		right: 20px;
		border-top-width: 1px;
		border-right-width: 1px;
	}

	.corner-bl {
		bottom: 20px;
		left: 20px;
		border-bottom-width: 1px;
		border-left-width: 1px;
	}

	.corner-br {
		bottom: 20px;
		right: 20px;
		border-bottom-width: 1px;
		border-right-width: 1px;
	}

	.name-container {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		position: relative;
		z-index: 1;
		margin-left: -80px;
	}

	.info-section {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.5rem;
		position: relative;
		z-index: 1;
		margin-left: -80px;
	}

	.scroll-indicator {
		position: absolute;
		bottom: 2rem;
		left: calc(50% - 40px);
		transform: translateX(-50%);
		display: flex;
		z-index: 10;
		flex-direction: column;
		align-items: center;
		gap: 0.5rem;
		opacity: 1;
		transition: opacity 0.3s ease;
	}

	.scroll-indicator.hidden {
		opacity: 0;
		pointer-events: none;
	}

	.name-row {
		display: flex;
		align-items: stretch;
		justify-content: center;
	}

	.first-name {
		font-size: 8rem;
		font-weight: 900;
		color: #1a1a1a;
		letter-spacing: -0.02em;
		line-height: 1;
	}

	.divider {
		width: 5px;
		background-color: #e63946;
		margin-left: 1rem;
		align-self: stretch;
	}

	.last-name {
		font-size: 3.2rem;
		font-weight: 400;
		color: #666;
		letter-spacing: 0.35em;
		text-transform: uppercase;
		margin-top: 0.5rem;
	}

	.decoration-line {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.dot {
		width: 6px;
		height: 6px;
		background-color: #e6394650;
		border-radius: 50%;
	}

	.line {
		width: 40px;
		height: 1px;
		background: linear-gradient(90deg, #e6394630, #e6394680);
	}

	.line-vertical {
		width: 1px;
		height: 20px;
		background-color: #e6394660;
	}

	.diamond {
		width: 12px;
		height: 12px;
		background-color: #e63946;
		transform: rotate(45deg);
		animation: pulse-diamond 2s ease-in-out infinite;
	}

	@keyframes pulse-diamond {
		0%, 100% {
			transform: rotate(45deg) scale(1);
			opacity: 1;
		}
		50% {
			transform: rotate(45deg) scale(1.1);
			opacity: 0.8;
		}
	}

