---
import '../styles/global.css';
import Layout from '../layouts/Layout.astro';
---

<Layout title="Caio Teixeira | Portfolio">
	<main>
		<div class="name-container">
			<div class="name-row">
				<span class="first-name">CAIO</span>
				<span class="divider"></span>
			</div>
			<span class="last-name">TEIXEIRA</span>
		</div>
	</main>
</Layout>

<style>
	main {
		width: 100%;
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.name-container {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
	}

	.name-row {
		display: flex;
		align-items: stretch;
		justify-content: center;
	}

	.first-name {
		font-size: 8rem;
		font-weight: 900;
		color: #1a1a1a;
		letter-spacing: -0.02em;
		line-height: 1;
	}

	.divider {
		width: 5px;
		background-color: #e63946;
		margin-left: 1rem;
		align-self: stretch;
	}

	.last-name {
		font-size: 3.2rem;
		font-weight: 400;
		color: #888;
		letter-spacing: 0.35em;
		text-transform: uppercase;
		margin-top: 0.5rem;
	}

	@media (max-width: 768px) {
		.first-name {
			font-size: 4rem;
		}

		.divider {
			width: 3px;
			margin-left: 0.5rem;
		}

		.last-name {
			font-size: 1.8rem;
			letter-spacing: 0.25em;
		}
	}
</style>
