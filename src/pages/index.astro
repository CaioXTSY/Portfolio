---
import '../styles/global.css';
import Layout from '../layouts/Layout.astro';
---

<Layout title="Caio Teixeira | Portfolio">
	<main>
		<div class="name-container">
			<div class="name-row">
				<span class="first-name">CAIO</span>
				<span class="divider"></span>
			</div>
			<span class="last-name">TEIXEIRA</span>
		</div>

		<div class="info-section">
			<div class="decoration-line">
				<span class="dot"></span>
				<span class="line"></span>
				<span class="line-vertical"></span>
				<span class="diamond"></span>
				<span class="line-vertical"></span>
				<span class="line"></span>
				<span class="dot"></span>
			</div>

			<div class="role">
				<span class="role-line"></span>
				<span class="role-text">FULLSTACK DEVELOPER</span>
				<span class="role-line"></span>
			</div>

			<div class="status-row">
				<div class="status-item">
					<span class="status-dot available"></span>
					<span class="status-text">AVAILABLE</span>
				</div>
				<span class="status-diamond"></span>
				<div class="status-item">
					<span class="status-dot location"></span>
					<span class="status-text">BRAZIL</span>
				</div>
			</div>
		</div>
	</main>
</Layout>

<style>
	main {
		width: 100%;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 3rem;
	}

	.name-container {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
	}

	.name-row {
		display: flex;
		align-items: stretch;
		justify-content: center;
	}

	.first-name {
		font-size: 8rem;
		font-weight: 900;
		color: #1a1a1a;
		letter-spacing: -0.02em;
		line-height: 1;
	}

	.divider {
		width: 5px;
		background-color: #e63946;
		margin-left: 1rem;
		align-self: stretch;
	}

	.last-name {
		font-size: 3.2rem;
		font-weight: 400;
		color: #888;
		letter-spacing: 0.35em;
		text-transform: uppercase;
		margin-top: 0.5rem;
	}

	/* Info Section */
	.info-section {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.5rem;
	}

	/* Decoration Line */
	.decoration-line {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.dot {
		width: 6px;
		height: 6px;
		background-color: #e6394650;
		border-radius: 50%;
	}

	.line {
		width: 40px;
		height: 1px;
		background: linear-gradient(90deg, #e6394630, #e6394680);
	}

	.line-vertical {
		width: 1px;
		height: 20px;
		background-color: #e6394660;
	}

	.diamond {
		width: 12px;
		height: 12px;
		background-color: #e63946;
		transform: rotate(45deg);
		animation: pulse-diamond 2s ease-in-out infinite;
	}

	@keyframes pulse-diamond {
		0%, 100% {
			transform: rotate(45deg) scale(1);
			opacity: 1;
		}
		50% {
			transform: rotate(45deg) scale(1.1);
			opacity: 0.8;
		}
	}

	/* Role */
	.role {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.role-line {
		width: 30px;
		height: 1px;
		background-color: #e6394660;
	}

	.role-text {
		font-size: 1rem;
		font-weight: 500;
		color: #888;
		letter-spacing: 0.3em;
	}

	/* Status Row */
	.status-row {
		display: flex;
		align-items: center;
		gap: 2rem;
	}

	.status-item {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.status-dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
	}

	.status-dot.available {
		background-color: #22c55e;
		animation: pulse-dot 2s ease-in-out infinite;
	}

	.status-dot.location {
		background-color: #e63946;
	}

	@keyframes pulse-dot {
		0%, 100% {
			box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.4);
		}
		50% {
			box-shadow: 0 0 0 6px rgba(34, 197, 94, 0);
		}
	}

	.status-text {
		font-size: 0.85rem;
		font-weight: 500;
		color: #888;
		letter-spacing: 0.15em;
	}

	.status-diamond {
		width: 6px;
		height: 6px;
		background-color: #e6394650;
		transform: rotate(45deg);
	}

	@media (max-width: 768px) {
		main {
			gap: 2rem;
		}

		.first-name {
			font-size: 4rem;
		}

		.divider {
			width: 3px;
			margin-left: 0.5rem;
		}

		.last-name {
			font-size: 1.8rem;
			letter-spacing: 0.25em;
		}

		.line {
			width: 20px;
		}

		.role-text {
			font-size: 0.8rem;
			letter-spacing: 0.2em;
		}

		.status-row {
			gap: 1rem;
		}

		.status-text {
			font-size: 0.75rem;
		}
	}
</style>
