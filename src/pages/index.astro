	/* Carousel */
	.carousel-container {
		display: flex;
		align-items: center;
		gap: 2rem;
		width: 100%;
		max-width: 1400px;
		margin-left: -80px;
		position: relative;
		z-index: 2;
	}

	.carousel-viewport {
		flex: 1;
		overflow: hidden;
		padding: 2rem 0;
	}

	.carousel-track {
		display: flex;
		gap: 24px;
		cursor: grab;
		transition: transform 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
		user-select: none;
	}

	.carousel-btn {
		width: 56px;
		height: 56px;
		border: 2px solid #e63946;
		background: transparent;
		color: #e63946;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		flex-shrink: 0;
		position: relative;
		overflow: hidden;
	}

	.carousel-btn::before {
		content: '';
		position: absolute;
		inset: 0;
		background: #e63946;
		transform: translateX(-100%);
		transition: transform 0.3s ease;
	}

	.carousel-btn:hover::before {
		transform: translateX(0);
	}

	.carousel-btn svg {
		position: relative;
		z-index: 1;
		transition: color 0.3s ease;
	}

	.carousel-btn:hover {
		box-shadow: 0 0 20px #e6394650;
	}

	.carousel-btn:hover svg {
		color: #ffffff;
	}

	.carousel-indicators {
		display: flex;
		justify-content: center;
		gap: 12px;
		margin-top: 2rem;
		margin-left: -80px;
		position: relative;
		z-index: 2;
	}

	.indicator {
		width: 12px;
		height: 12px;
		border: 2px solid #e6394650;
		background: transparent;
		cursor: pointer;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		transform: rotate(45deg);
		padding: 0;
		position: relative;
	}

	.indicator::after {
		content: '';
		position: absolute;
		inset: 2px;
		background: #e63946;
		transform: scale(0);
		transition: transform 0.3s ease;
	}

	.indicator:hover {
		border-color: #e63946;
		box-shadow: 0 0 10px #e6394650;
	}

	.indicator:hover::after,
	.indicator.active::after {
		transform: scale(1);
	}

	.indicator.active {
		background: #e63946;
		border-color: #e63946;
		box-shadow: 0 0 15px #e6394680;
	}

	.project-card {
